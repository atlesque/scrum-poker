{
  "name": "scrum-poker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @scrum-poker/worker --filter @scrum-poker/frontend dev",
    "dev:worker": "pnpm --filter @scrum-poker/worker dev",
    "dev:frontend": "pnpm --filter @scrum-poker/frontend dev",
    "build": "pnpm --filter @scrum-poker/shared build && pnpm --filter @scrum-poker/worker build && pnpm --filter @scrum-poker/frontend build",
    "test": "pnpm --filter @scrum-poker/shared test && pnpm --filter @scrum-poker/worker test",
    "test:shared": "pnpm --filter @scrum-poker/shared test",
    "test:worker": "pnpm --filter @scrum-poker/worker test"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
